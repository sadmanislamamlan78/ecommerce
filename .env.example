# Django
SECRET_KEY=your-django-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase (Project Settings → API)
# Project URL only — NO /rest/v1 at the end
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-publishable-key-here
# Optional: for server-side admin tasks (keep secret, never expose in frontend)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase PostgreSQL (Project Settings → Database → Connection string)
# Use "Session mode" pooler for Django, or direct connection for local dev
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432

# Set to True once PostgreSQL credentials above are configured
USE_SUPABASE_DB=False

# SSL — REQUIRED on many Windows/Python 3.14 setups (fixes sign-in + products)
SUPABASE_SSL_VERIFY=false
